{
  "name": "anixapi",
  "version": "0.2.1",
  "description": "Unofficial Anixart API wrapper for Node.js (TypeScript)",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "docs/DOCUMENTATION.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run typecheck && npm run clean && tsc",
    "build-win": "npm run build",
    "prepublishOnly": "npm run build",
    "publish:npm": "npm publish --access public",
    "publish:yarn": "yarn publish"
  },
  "keywords": [
    "api",
    "anixart",
    "anixapi",
    "wrapper",
    "anime",
    "typescript"
  ],
  "homepage": "https://github.com/Maks1mio/anixapi#readme",
  "bugs": {
    "url": "https://github.com/Maks1mio/anixapi/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Maks1mio/anixapi.git"
  },
  "author": "Roman U. (DesConnet) & Maksim K. (Maks1mio)",
  "license": "GPL-2.0",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "form-data": "^4.0.2"
  }
}
